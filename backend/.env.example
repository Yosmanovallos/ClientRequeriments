# ── Provider switches (flip to migrate to Microsoft) ──────────────────────────
AUTH_PROVIDER=local-jwt       # local | local-jwt | supabase | entra
STORAGE_PROVIDER=local        # local | supabase | azureblob
TICKETS_PROVIDER=local        # local | github | azuredevops
NOTIFY_PROVIDER=local         # local | smtp | slack | teams | composite | microsoft

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/clientrequirements

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# ── Auth (local-jwt adapter) ──────────────────────────────────────────────────
LOCAL_JWT_SECRET=                     # Required for AUTH_PROVIDER=local-jwt. 32+ random chars. Keep secret.
DEMO_FALLBACK_CLIENT_ID=00000000-0000-0000-0000-000000000001

# ── Auth (Supabase adapter) ────────────────────────────────────────────────────
# Get these from Supabase Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=                  # Required for AUTH_PROVIDER=supabase (HS256 secret)
DEMO_FALLBACK_CLIENT_ID=              # DEV-ONLY: used when token has no client_id claim. Leave empty in production.

# ── Auth (Entra External ID adapter — Phase 9) ────────────────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_JWKS_URI=

# ── Storage (Supabase adapter) ─────────────────────────────────────────────────
SUPABASE_STORAGE_BUCKET=attachments

# ── Storage (Azure Blob adapter — Phase 9) ────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=attachments

# ── Tickets (GitHub Issues adapter) ───────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
# Required for inbound webhooks (Settings → Webhooks → Secret on the GitHub repo)
GITHUB_WEBHOOK_SECRET=

# ── Tickets (Azure DevOps adapter) ────────────────────────────────────────────
# Create PAT at: https://dev.azure.com/<org>/_usersSettings/tokens
# Required scope: Work Items (Read, write, & manage)
ADO_ORG=                              # e.g. "your-org" (the bit after dev.azure.com/)
ADO_PROJECT=                          # exact case-sensitive project name
ADO_PAT=                              # the PAT token
ADO_WORK_ITEM_TYPE=Task               # Task | Bug | User Story | Issue (must exist in project's process template)
ADO_API_URL=                          # OPTIONAL: override for Azure DevOps Server on-prem (default: https://dev.azure.com)
ADO_STATE_MAP_JSON=                   # OPTIONAL: override status mapping. Default is Agile process.
                                      # Example for Scrum: {"DONE":{"state":"Done","reason":"Work finished"},"CANCELLED":{"state":"Removed","reason":"Abandoned"}}

# ── Tickets (Azure DevOps inbound webhook — Service Hooks) ────────────────────
# Required for /webhooks/azuredevops to be registered. Configure these as Basic Auth on the
# ADO subscription: Project Settings → Service hooks → + → Web Hooks → Basic Auth section.
ADO_WEBHOOK_USER=
ADO_WEBHOOK_PASS=

# ── Notifications (SMTP adapter — works for Resend, SendGrid, Outlook, etc.) ──
SMTP_HOST=smtp.resend.com             # Outlook personal/M365: smtp.office365.com
SMTP_PORT=465                         # Outlook M365: 587 (STARTTLS)
SMTP_USER=resend                      # Outlook M365: your email address
SMTP_PASS=                            # Outlook M365: APP PASSWORD (NOT login password — see docs/environments.md)
NOTIFY_FROM=noreply@yourdomain.com    # Outlook M365: must match SMTP_USER's mailbox
NOTIFY_TO_DEFAULT=team@yourdomain.com

# ── Notifications (channel — pick ONE; Teams takes priority if both set) ──────
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=                    # Teams channel → ⋯ → Workflows → "Post to a channel when a webhook request is received"

# ── Notifications (full Microsoft Graph — Phase 9 only, app-registration needed) ──
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
