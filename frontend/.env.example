# ── Frontend env vars ─────────────────────────────────────────────────────────
# Only VITE_-prefixed vars are exposed to the browser.

# Backend API base. Leave unset to use the Vite proxy (dev) or the same-origin
# /api rewrite in production (configured in vercel.json).
VITE_API_URL=

# Supabase Auth — only needed if backend uses AUTH_PROVIDER=supabase.
# Otherwise leave both blank and the login form shows "demo mode".
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
